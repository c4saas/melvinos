# ─────────────────────────────────────────────
#  MelvinOS — Environment Configuration
#  Copy this file to .env and fill in values.
#  Generate secrets with: openssl rand -hex 32
# ─────────────────────────────────────────────

# ── Server ───────────────────────────────────
NODE_ENV=production
PORT=3001
COOKIE_SECURE=true

# Generate with: openssl rand -hex 32
SESSION_SECRET=changeme_replace_with_openssl_rand_hex_32

# ── Security ─────────────────────────────────
# Generate with: openssl rand -hex 32
API_KEY_ENCRYPTION_KEY=

# Set a temporary password for admin enrollment, then clear it after setup.
ADMIN_ENROLLMENT_SECRET=

# ── Database ─────────────────────────────────
# Docker Compose: use the service name "postgres" as the host.
#   DATABASE_URL=postgres://atlas:YOUR_POSTGRES_PASSWORD@postgres:5432/atlasai
# Local dev:
#   DATABASE_URL=postgres://user:pass@localhost:5432/atlasai
DATABASE_URL=postgres://atlas:changeme@postgres:5432/atlasai

# ── Docker Compose ───────────────────────────
# Password for the PostgreSQL container (must match DATABASE_URL above).
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=changeme

# Host port to expose the app on (maps HOST_PORT → container port 3001).
HOST_PORT=3001

# ── Licensing ────────────────────────────────
# Temporary pro-access code (until Stripe webhooks are configured).
PRO_ACCESS_CODE=

# ── AI Providers ─────────────────────────────
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Voice: leave blank to inherit OPENAI_API_KEY.
OPENAI_VOICE_API_KEY=

# Optional overrides for server-managed voice defaults.
OPENAI_VOICE_MODEL=gpt-4o-mini-tts
OPENAI_VOICE_NAME=alloy
OPENAI_VOICE_FORMAT=mp3

# Enable OpenAI Realtime WebSocket voice streaming.
OPENAI_VOICE_REALTIME_ENABLED=false
OPENAI_VOICE_REALTIME_URL=

# ── Knowledge Base ────────────────────────────
# Optional comma-separated allowlist of hosts the agent can fetch for ingestion.
KNOWLEDGE_FETCH_HOST_ALLOWLIST=

# ── File Storage ─────────────────────────────
FILE_STORAGE_TTL_MS=86400000
FILE_STORAGE_QUOTA_BYTES=52428800

# ── Usage Aggregation ────────────────────────
USAGE_SNAPSHOT_INTERVAL_MINUTES=15
USAGE_SNAPSHOT_LOOKBACK_HOURS=24

# ── S3 / Cloudflare R2 (optional) ────────────
# Enables persistent signed-URL file storage instead of in-memory.
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Deployment ────────────────────────────────
# Set to true to skip automatic DB migrations on startup.
SKIP_DB_MIGRATIONS=false
